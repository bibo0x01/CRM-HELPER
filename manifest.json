{
    "manifest_version": 3,
    "name": "CRM Quick Replies",
    "version": "1.1",
    "description": "Quick replies and customer collector for onboarding chat",
    "permissions": [
        "activeTab",
        "storage"
    ],
    "host_permissions": [
        "https://old-app.easyconfirm.net/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://old-app.easyconfirm.net/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "style.css"
            ]
        }
    ]
}